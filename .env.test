# E2E Test Configuration
# This file is used by docker-compose-test.yml

NEXT_PUBLIC_BASE_DOMAIN=localhost
EMAIL=test@example.com

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test_password
POSTGRES_DB=skerry
DATABASE_URL=postgres://postgres:test_password@postgres:5432/skerry

# Security
SESSION_SECRET=test_session_secret

# Matrix (Synapse)
SYNAPSE_BASE_URL=http://synapse:8008
SYNAPSE_AS_TOKEN=test_as_token
SYNAPSE_HS_TOKEN=test_hs_token
SYNAPSE_AS_REGISTRATION_PATH=/app/docker/synapse/skerry-appservice.yaml
SYNAPSE_STRICT_PROVISIONING=false

# Voice & Video (LiveKit)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=test_livekit_key
LIVEKIT_API_SECRET=test_livekit_secret
SFU_TOKEN_TTL_SECONDS=300

# Authentication
# Discord OIDC is disabled to keep the UI clean for E2E tests (Developer Login only)

# Development & Debugging
DEV_AUTH_BYPASS=true
SETUP_BOOTSTRAP_ENABLED=true
SETUP_BOOTSTRAP_TOKEN=test_bootstrap_token
RATE_LIMIT_PER_MINUTE=6000
NODE_ENV=test
