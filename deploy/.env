# REQUIRED — your domain (e.g. skerry.chat, or localhost for testing)
BASE_DOMAIN=

# ==========================================
# Optional — OAuth Providers
# ==========================================
# Uncomment any to enable. Skipping a provider disables that login method.
#
# Discord (login + optional bridge with DISCORD_BOT_TOKEN)
#DISCORD_CLIENT_ID=
#DISCORD_CLIENT_SECRET=
#DISCORD_BOT_TOKEN=

# Google
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# Twitch
#TWITCH_CLIENT_ID=
#TWITCH_CLIENT_SECRET=

# ==========================================
# Optional — Email (LetsEncrypt notifications)
# ==========================================
#EMAIL=

# ==========================================
# Auto-generated secrets (uncomment to override, e.g. for migration)
# ==========================================
#POSTGRES_PASSWORD=autogenerated
#SESSION_SECRET=autogenerated
#SYNAPSE_AS_TOKEN=autogenerated
#SYNAPSE_HS_TOKEN=autogenerated
#LIVEKIT_API_KEY=autogenerated
#LIVEKIT_API_SECRET=autogenerated
#SETUP_BOOTSTRAP_TOKEN=autogenerated

# ==========================================
# Overrides (rarely needed — defaults shown)
# ==========================================
#SKERRY_VERSION=v0.1.0-alpha
#POSTGRES_USER=skerry
#POSTGRES_DB=skerry
