{
  "name": "@escapehatch/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx dotenv-cli -e ../../.env -- next dev",
    "build": "next build",
    "start": "npx dotenv-cli -e ../../.env -- next start -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npx dotenv-cli -e ../../.env -- tsx --test test/*.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@escapehatch/shared": "workspace:*",
    "@matrix-org/matrix-sdk-crypto-wasm": "^17.1.0",
    "emoji-picker-react": "^4.18.0",
    "livekit-client": "^2.17.2",
    "matrix-js-sdk": "^40.3.0-rc.0",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.30",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}