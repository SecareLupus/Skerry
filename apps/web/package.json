{
  "name": "@skerry/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx dotenv-cli -e ../../.env -- next dev",
    "build": "next build",
    "start": "npx dotenv-cli -e ../../.env -- next start -H 0.0.0.0",
    "start:prod": "next start -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npx dotenv-cli -e ../../.env.test -o -- tsx --test test/*.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-wasm": "^17.1.0",
    "@skerry/shared": "workspace:*",
    "dompurify": "^3.3.3",
    "emoji-picker-react": "^4.18.0",
    "livekit-client": "^2.17.2",
    "lottie-react": "^2.4.1",
    "matrix-js-sdk": "^40.3.0-rc.0",
    "next": "14.2.30",
    "prismjs": "^1.30.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^9.1.0",
    "react-simple-code-editor": "^0.14.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.30",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}