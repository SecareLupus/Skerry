{
  "name": "@skerry/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx dotenv-cli -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "npx dotenv-cli -e ../../.env -- node dist/index.js",
    "start:prod": "node dist/index.js",
    "lint": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npx dotenv-cli -e ../../.env.test -e .env.test -o -- tsx src/test/setup-test-db.ts && npx dotenv-cli -e ../../.env.test -e .env.test -o -- tsx --test --test-concurrency=1 src/test/*.test.ts",
    "migrate:up": "npx dotenv-cli -e ../../.env -- node-pg-migrate up --migrations-dir migrations",
    "migrate:down": "npx dotenv-cli -e ../../.env -- node-pg-migrate down --migrations-dir migrations",
    "migrate:create": "npx dotenv-cli -e ../../.env -- node-pg-migrate create --migrations-dir migrations",
    "check-migrations": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/skerry npx dotenv-cli -e ../../.env -- tsx src/test/check-migrations.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.2",
    "@skerry/shared": "workspace:*",
    "cheerio": "^1.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.1.0",
    "livekit-server-sdk": "^2.15.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cheerio": "^1.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}