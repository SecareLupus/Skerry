{
  "name": "skerry",
  "version": "0.1.0",
  "private": true,
  "description": "Skerry Collective platform monorepo",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @skerry/control-plane --filter @skerry/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @skerry/web test:e2e",
    "test:all": "pnpm test && pnpm test:e2e"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@types/nodemailer": "^7.0.11",
    "nodemailer": "^8.0.4",
    "prom-client": "^15.1.3"
  }
}
