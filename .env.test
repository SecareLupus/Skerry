# Automated E2E Test Configuration
# This file is tuned for CI and local headless testing.
# It enables development bypasses and disables rate-limiting to prevent test flakiness.

NODE_ENV=test
PORT=3000

# Security Bypasses (Essential for headless tests)
DEV_AUTH_BYPASS=true
SETUP_BOOTSTRAP_ENABLED=true
SETUP_BOOTSTRAP_TOKEN=test_bootstrap_token

# Performance & Stability Tuning
# Increased rate limit to prevent 429s during rapid E2E setup/teardown
RATE_LIMIT_PER_MINUTE=1000
SFU_TOKEN_TTL_SECONDS=600

# Database Configuration (Point to a test database if available)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=temporary_battery_horse_staple_password
POSTGRES_DB=escapehatch_test
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Internal Service Networking
SYNAPSE_BASE_URL=http://synapse:8008
SYNAPSE_AS_TOKEN=test_as_token
SYNAPSE_HS_TOKEN=test_hs_token
SYNAPSE_STRICT_PROVISIONING=false

LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# S3 / Storage (Mocked or local minio)
S3_BUCKET=escapehatch-test
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL_PREFIX=http://localhost:9000/${S3_BUCKET}

# Bridge Configuration (Disabled for core UI tests)
DISCORD_BRIDGE_BOT_TOKEN=
